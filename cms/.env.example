HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# --- Frontend base URL (used for Stripe redirect URLs) ---
FRONTEND_URL=http://localhost:5173

# --- Stripe configuration (NEVER commit real secrets in .env.example) ---
# Secret key used server-side only
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook signing secret from Stripe dashboard (Developers > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional: if you create a fixed Price in Stripe dashboard for a common donation amount
# keep it; for dynamic custom amounts you won't need this.
STRIPE_PRICE_DONATION=

# Currency (ISO 4217). All stored amounts are in minor units (cents, bani etc.)
DONATION_CURRENCY=RON
