###############################################
# Strapi Environment Example
# Strategy: SQLite now, ready for Postgres later
###############################################

HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2,toBeModified3,toBeModified4"
API_TOKEN_SALT=tobemodified_api_salt
ADMIN_JWT_SECRET=tobemodified_admin_jwt
TRANSFER_TOKEN_SALT=tobemodified_transfer_salt
JWT_SECRET=tobemodified_public_jwt
ENCRYPTION_KEY=tobemodified_encryption

# --- Frontend base URL (used for Stripe redirect URLs) ---
FRONTEND_URL=http://localhost:5173
PUBLIC_URL=http://localhost:1337
// CORS extra origins (separate prin virgule)
CORS_EXTRA_ORIGINS=

# --- Stripe configuration (NEVER commit real secrets in .env.example) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional: if you create a fixed Price in Stripe dashboard for a common donation amount
# keep it; for dynamic custom amounts you won't need this.
STRIPE_PRICE_DONATION=

# Currency (ISO 4217). All stored amounts are in minor units (cents, bani etc.)
DONATION_CURRENCY=RON

# ---- Database (Active: SQLite) ----
DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db

###############################################
# ---- Postgres Block (switch when migrating) ----
# Option 1 (recommended): single DATABASE_URL
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST.supabase.co:5432/postgres?schema=public
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10

# Option 2 (legacy discrete vars):
# DATABASE_CLIENT=postgres
# DATABASE_HOST=YOUR_HOST.supabase.co
# DATABASE_PORT=5432
# DATABASE_NAME=postgres
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=YOUR_PASSWORD
# DATABASE_SCHEMA=public
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10
###############################################

# ---- Public URL (folosit pentru generare link absolut media dacă e necesar) ----
# PUBLIC_URL=https://asociatia-<id>.onrender.com

# ---- Feature Flags ----
FLAG_NPS=true
FLAG_PROMOTE_EE=true

# ---- Maintenance Scripts (run after imports/migrations) ----
# npm run sync:donations -- --dry
# npm run sync:donations
# npm run recompute:raised -- --dry
# npm run recompute:raised

# ---- Migration Notes ----
# 1. Start on SQLite (default above)
# 2. Create Postgres (Supabase) instance when volume grows
# 3. Uncomment Postgres block & set DATABASE_CLIENT=postgres
# 4. Set DATABASE_CLIENT=postgres + DATABASE_URL (or discrete vars) in .env
# 5. Run: npm run bootstrap:db  (creează tabele)
# 6. Creează admin: RESET_ADMIN_EMAIL=... RESET_ADMIN_PASSWORD=... npm run admin:create
# 7. Verifică rute: npm run debug:routes  (trebuie să listeze campanie-de-donatiis etc.)
# 8. (Optional) Export + re-import conținut sau repopulare manuală
# 9. Rulează scripturi întreținere (sync:donations / recompute:raised)
# 10. Smoke test: /api/homepage & /api/campanie-de-donatiis

