{
  "kind": "singleType",
  "collectionName": "homepages",
  "info": {
    "singularName": "homepage",
    "pluralName": "homepages",
    "displayName": "Homepage"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "heroTitle": { "type": "string", "required": true },
    "heroSubtitle": { "type": "string" },
    "heroDescription": { "type": "richtext" },
    "heroCtaText": { "type": "string" },
    "heroCtaLink": { "type": "string" },
    "heroBackgroundMedia": { "type": "media", "multiple": false },

    "statsYearsActive": { "type": "integer", "default": 0 },
    "statsTotalBeneficiaries": { "type": "integer", "default": 0 },
    "statsCompletedProjects": { "type": "integer", "default": 0 },
    "statsActiveVolunteers": { "type": "integer", "default": 0 },

    "howWeWorkTitle": { "type": "string" },
    "howWeWorkDescription": { "type": "richtext" },

    "impactGalleryTitle": { "type": "string" },
    "impactGalleryDescription": { "type": "richtext" },
    "impactGalleryImages": { "type": "media", "multiple": true },
    "teamMembers": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.team-member"
    },
    "worksteps": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.workstep"
    },

    "teamTitle": { "type": "string" },
    "teamDescription": { "type": "richtext" },

    "transparencyTitle": { "type": "string" },

    "donationIban": { "type": "string" },
    "donationBankName": { "type": "string" },
    "donationBeneficiaryName": { "type": "string" },
    "donationInstructions": { "type": "richtext" },
    "donationReferenceHint": { "type": "string" },

    "seoTitle": { "type": "string" },
    "seoDescription": { "type": "text" },
    "seoSocialImage": { "type": "media", "multiple": false }
  }
}
