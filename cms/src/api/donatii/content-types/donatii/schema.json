{
  "kind": "collectionType",
  "collectionName": "donatiis",
  "info": {
    "singularName": "donatii",
    "pluralName": "donatiis",
    "displayName": "donatii"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "campanie_de_donatii": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::campanie-de-donatii.campanie-de-donatii",
      "inversedBy": "donatiis"
    },
    "suma": {
      "type": "decimal",
      "required": true
    },
    "emailDonator": {
      "type": "email",
      "required": false
    },
    "numeDonator": {
      "type": "string"
    },
    "stare": {
      "type": "enumeration",
      "required": true,
      "enum": ["pending", "completed", "failed", "refunded"]
    },
    "metodaDePlata": {
      "type": "enumeration",
      "enum": ["card", "transfer bancar"]
    },
    "transactionId": {
      "type": "string"
    },
    "mesaj": {
      "type": "richtext"
    },
    "isAnonymous": {
      "type": "boolean",
      "default": false
    },
    "currency": {
      "type": "enumeration",
      "default": "RON",
      "enum": ["RON", "EUR", "USD"]
    },
    "stripePaymentIntentId": {
      "type": "string"
    },
    "receiptUrl": {
      "type": "string"
    },
    "amountInMinorUnit": {
      "type": "integer"
    },
    "netAmount": {
      "type": "integer"
    },
    "donorCountry": {
      "type": "string"
    },
    "stripeSessionId": {
      "type": "string",
      "unique": true
    }
  }
}
