# Base URL for API (include /api if backend exposes it at that path)
############################################################
# Frontend Environment Example
# Copiază acest fișier în `.env.local` pentru dezvoltare locală.
# Variabilele trebuie să înceapă cu VITE_ ca să fie expuse în client.
############################################################

# Local Strapi (development)
VITE_API_CMS_URL=http://localhost:1337/api

# Production Strapi (Render) – setează în `.env.local` când vrei să testezi remote.
# Exemplu (DE COMENTAT AICI, pune în .env.local real):
# VITE_API_BASE_URL=https://asociatia-<id>.onrender.com/api

# Timeout (ms) pentru fetch – ajută la cold start lung Render.
VITE_API_TIMEOUT_MS=8000

# Fallback static (0/1). Când 1 și avem export JSON, dacă API eșuează sau expiră
# se folosesc fișierele din /public/data/*.json.
VITE_FALLBACK_STATIC=0

# Forțează doar static (ignoră API) – util pentru test offline (viitor).
# VITE_FORCE_STATIC_ONLY=0

############################################################
